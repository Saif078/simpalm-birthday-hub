# Copy this to .env and fill in your values

ANTHROPIC_API_KEY=your_anthropic_api_key_here

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

